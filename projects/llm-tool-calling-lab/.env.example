# Copy to .env and fill in. NEVER commit .env (it is gitignored repo-wide).
# Only used on the "Upgrade path" in the README, when you swap FakeTransport for
# the real `anthropic` client. The lab itself runs with NO credentials.

# Your Anthropic API key from https://platform.claude.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: override the default model used by the real-client adapter.
# See https://platform.claude.com/docs/en/about-claude/models/overview
ANTHROPIC_MODEL=replace-with-current-model-id
